{
  "entities": {
    "User": {
      "title": "User",
      "description": "A player in the game.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "lastActive": { "type": "string", "description": "ISO string or Firestore Timestamp of last activity." },
        "health": { "type": "number" },
        "ammo": { "type": "number" },
        "coins": { "type": "number" },
        "points": { "type": "number" },
        "level": { "type": "number" },
        "squadId": { "type": "string" },
        "gunQuality": { "type": "string", "enum": ["cheap", "standard", "expensive", "elite"] },
        "shieldUntil": { "type": "string", "description": "ISO string or Firestore Timestamp." },
        "invisibleUntil": { "type": "string", "description": "ISO string or Firestore Timestamp." },
        "autoMissiles": { "type": "number" },
        "grenades": { "type": "number" },
        "territoryCount": { "type": "number" },
        "onlineStatus": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "health", "ammo", "coins", "points", "level", "gunQuality", "autoMissiles", "grenades", "territoryCount", "onlineStatus"]
    },
    "Attack": {
      "title": "Attack",
      "description": "A record of a combat action.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "attackerId": { "type": "string" },
        "targetId": { "type": "string" },
        "fromLat": { "type": "number" },
        "fromLng": { "type": "number" },
        "toLat": { "type": "number" },
        "toLng": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["bullet", "missile", "grenade"] }
      },
      "required": ["id", "attackerId", "targetId", "fromLat", "fromLng", "toLat", "toLng", "timestamp", "type"]
    },
    "Squad": {
      "title": "Squad",
      "description": "A team of players.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "leaderId": { "type": "string" },
        "score": { "type": "number" },
        "avatarUrl": { "type": "string" },
        "territoryCount": { "type": "number" },
        "isWeeklyWinner": { "type": "boolean" }
      },
      "required": ["id", "name", "leaderId", "score", "territoryCount"]
    },
    "Treasure": {
      "title": "Treasure",
      "description": "A lootable item on the map.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "coins": { "type": "number" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "lat", "lng", "coins", "active", "createdAt"]
    },
    "Territory": {
      "title": "Territory",
      "description": "A conquerable area on the map.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "ownerSquadId": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "ownerSquadId", "lat", "lng", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores player profiles and real-time state."
    },
    "/squads/{squadId}": {
      "schema": { "$ref": "#/entities/Squad" },
      "description": "Stores squad information."
    },
    "/treasures/{treasureId}": {
      "schema": { "$ref": "#/entities/Treasure" },
      "description": "Stores active treasures on the map."
    },
    "/territories/{territoryId}": {
      "schema": { "$ref": "#/entities/Territory" },
      "description": "Stores territory ownership."
    },
    "/attacks/{attackId}": {
      "schema": { "$ref": "#/entities/Attack" },
      "description": "Stores real-time attack animations."
    }
  }
}
