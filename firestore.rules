rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string &&
             data.username is string && data.username.size() >= 1 && data.username.size() <= 100 &&
             data.territories is number &&
             data.points is number &&
             data.level is number &&
             data.isAnonymous is bool;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      
      allow update: if isOwner(userId) && 
                    isValidUser(request.resource.data) &&
                    request.resource.data.uid == resource.data.uid;
                    
      allow delete: if false;
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Allow game data for now (to be hardened later)
    match /squads/{squadId} { allow read, write: if isAuthenticated(); }
    match /treasures/{treasureId} { allow read, write: if isAuthenticated(); }
    match /territories/{territoryId} { allow read, write: if isAuthenticated(); }
    match /attacks/{attackId} { allow read, write: if isAuthenticated(); }
  }
}
