rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 50 &&
             data.territories is number && data.territories >= 0 &&
             data.points is number && data.points >= 0 &&
             data.level is number && data.level >= 1 &&
             data.isAnonymous is bool;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================
    
    match /users/{userId} {
      // Users can read their own profile, or others can read basic info (if needed)
      // For now, let's keep it restricted to authenticated users for discovery
      allow read: if isAuthenticated();
      
      // Only the owner can create their document, and it must be valid
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      
      // Only the owner can update their document
      // We also ensure critical fields like uid and createdAt don't change
      allow update: if isOwner(userId) && 
                    isValidUser(request.resource.data) &&
                    request.resource.data.uid == resource.data.uid &&
                    request.resource.data.createdAt == resource.data.createdAt;
                    
      allow delete: if false; // Users cannot delete their accounts via client
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Allow game data for now (to be hardened later)
    match /squads/{squadId} { allow read, write: if isAuthenticated(); }
    match /treasures/{treasureId} { allow read, write: if isAuthenticated(); }
    match /territories/{territoryId} { allow read, write: if isAuthenticated(); }
    match /attacks/{attackId} { allow read, write: if isAuthenticated(); }
  }
}
