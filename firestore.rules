rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isPositive(field) {
      return request.resource.data[field] is number && request.resource.data[field] >= 0;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() <= 50 &&
             data.health is number && data.health >= 0 && data.health <= 100 &&
             data.ammo is number && data.ammo >= 0 &&
             data.coins is number && data.coins >= 0 &&
             data.gunQuality in ['cheap', 'standard', 'expensive'] &&
             data.autoMissiles is number && data.autoMissiles >= 0;
    }

    function isValidSquad(data) {
      return data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 30 &&
             data.leaderId is string && data.leaderId.size() > 0 &&
             data.score is number && data.score >= 0;
    }

    function isValidTreasure(data) {
      return data.id is string && data.id.size() > 0 &&
             data.lat is number && data.lng is number &&
             data.coins is number && data.coins > 0 &&
             data.active is bool;
    }

    function isValidTerritory(data) {
      return data.id is string && data.id.size() > 0 &&
             data.ownerSquadId is string && data.ownerSquadId.size() > 0 &&
             data.lat is number && data.lng is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Anyone authenticated can read user locations and basic stats for the map
      allow read: if isAuthenticated();
      
      // Users can only create their own profile
      allow create: if isOwner(userId) && 
                    hasRequiredFields(['uid', 'displayName', 'health', 'ammo', 'coins', 'gunQuality', 'autoMissiles']) &&
                    isValidUser(request.resource.data) &&
                    uidUnchanged();
                    
      // Users can update their own profile, or other users can update health (when shooting)
      // For a real game, shooting logic should ideally be on a server to prevent cheating,
      // but for this prototype, we allow authenticated users to update health.
      allow update: if isAuthenticated() && 
                    isValidUser(request.resource.data) &&
                    uidNotModified() &&
                    (isOwner(userId) || 
                     // When someone else updates, they can ONLY decrease health
                     (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['health']) &&
                      request.resource.data.health < resource.data.health));
    }

    match /squads/{squadId} {
      allow read: if isAuthenticated();
      
      // Any authenticated user can create a squad
      allow create: if isAuthenticated() && 
                    hasRequiredFields(['id', 'name', 'leaderId', 'score']) &&
                    isValidSquad(request.resource.data) &&
                    request.resource.data.leaderId == request.auth.uid;
                    
      // Only the leader can update the squad (e.g., changing name/avatar)
      // Or anyone can update the score (prototype simplification)
      allow update: if isAuthenticated() && 
                    isValidSquad(request.resource.data) &&
                    (request.auth.uid == resource.data.leaderId || 
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['score']));
    }

    match /treasures/{treasureId} {
      allow read: if isAuthenticated();
      
      // Treasures are created by the system/admin, but for prototype we might allow clients to spawn them
      allow create: if isAuthenticated() && 
                    hasRequiredFields(['id', 'lat', 'lng', 'coins', 'active', 'createdAt']) &&
                    isValidTreasure(request.resource.data);
                    
      // Anyone can collect a treasure (set active to false)
      allow update: if isAuthenticated() && 
                    isValidTreasure(request.resource.data) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['active']) &&
                    request.resource.data.active == false && resource.data.active == true;
    }

    match /territories/{territoryId} {
      allow read: if isAuthenticated();
      
      // Anyone can claim a territory
      allow create: if isAuthenticated() && 
                    hasRequiredFields(['id', 'ownerSquadId', 'lat', 'lng']) &&
                    isValidTerritory(request.resource.data);
                    
      // Anyone can update territory owner
      allow update: if isAuthenticated() && 
                    isValidTerritory(request.resource.data) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ownerSquadId']);
    }
  }
}
