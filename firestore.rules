rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isPositive(field) {
      return request.resource.data[field] is number && request.resource.data[field] >= 0;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return (!('uid' in data) || (data.uid is string && data.uid.size() > 0)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('health' in data) || (data.health is number && data.health >= 0)) &&
             (!('ammo' in data) || (data.ammo is number)) &&
             (!('coins' in data) || (data.coins is number)) &&
             (!('gunQuality' in data) || data.gunQuality is string) &&
             (!('autoMissiles' in data) || (data.autoMissiles is number)) &&
             (!('grenades' in data) || (data.grenades is number)) &&
             (!('territoryCount' in data) || (data.territoryCount is number)) &&
             (!('onlineStatus' in data) || (data.onlineStatus is bool)) &&
             (!('lat' in data) || data.lat is number) &&
             (!('lng' in data) || data.lng is number) &&
             (!('lastActive' in data) || data.lastActive is string || data.lastActive == null) &&
             (!('photoURL' in data) || data.photoURL is string || data.photoURL == null) &&
             (!('squadId' in data) || data.squadId is string || data.squadId == null) &&
             (!('shieldUntil' in data) || data.shieldUntil is string || data.shieldUntil == null) &&
             (!('invisibleUntil' in data) || data.invisibleUntil is string || data.invisibleUntil == null);
    }

    function isValidSquad(data) {
      return data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 &&
             data.leaderId is string && data.leaderId.size() > 0 &&
             data.score is number &&
             (!('territoryCount' in data) || data.territoryCount is number) &&
             (!('isWeeklyWinner' in data) || data.isWeeklyWinner is bool) &&
             (!('avatarUrl' in data) || data.avatarUrl is string || data.avatarUrl == null);
    }

    function isValidTreasure(data) {
      return data.id is string && data.id.size() > 0 &&
             data.lat is number && data.lng is number &&
             data.coins is number &&
             data.active is bool &&
             (!('createdAt' in data) || data.createdAt is string || data.createdAt == null);
    }

    function isValidTerritory(data) {
      return data.id is string && data.id.size() > 0 &&
             data.ownerId is string &&
             data.ownerSquadId is string &&
             data.lat is number && data.lng is number &&
             (!('createdAt' in data) || data.createdAt is string || data.createdAt == null);
    }

    function isValidAttack(data) {
      return data.id is string && data.id.size() > 0 &&
             data.attackerId is string && data.attackerId.size() > 0 &&
             data.targetId is string && data.targetId.size() > 0 &&
             data.fromLat is number && data.fromLng is number &&
             data.toLat is number && data.toLng is number &&
             data.type is string &&
             (data.timestamp is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Anyone authenticated can read user locations and basic stats for the map
      allow read: if isAuthenticated();
      
      // Users can only create their own profile, or anyone can create bots
      allow create: if (isOwner(userId) && 
                    hasRequiredFields(['uid', 'displayName', 'health', 'ammo', 'coins', 'gunQuality', 'autoMissiles', 'grenades', 'territoryCount', 'onlineStatus']) &&
                    isValidUser(request.resource.data) &&
                    uidUnchanged()) || 
                    (isAuthenticated() && userId.matches('^bot_.*'));
                    
      // Users can update their own profile, or other users can update health (when shooting)
      // Anyone can update bots
      allow update: if isAuthenticated() && 
                    isValidUser(request.resource.data) &&
                    uidNotModified() &&
                    (isOwner(userId) || 
                     userId.matches('^bot_.*') ||
                     // When someone else updates, they can ONLY decrease health or update territoryCount (for kills)
                     (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['health', 'territoryCount']) &&
                      request.resource.data.health <= resource.data.health) ||
                     (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['health'])) ||
                     (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['territoryCount'])));

      // Anyone can delete bots
      allow delete: if isAuthenticated() && userId.matches('^bot_.*');
    }

    match /squads/{squadId} {
      allow read: if isAuthenticated();
      
      // Any authenticated user can create a squad
      allow create: if isAuthenticated() && 
                    hasRequiredFields(['id', 'name', 'leaderId', 'score']) &&
                    isValidSquad(request.resource.data) &&
                    (request.resource.data.leaderId == request.auth.uid || request.resource.data.leaderId.matches('^bot_.*'));
                    
      // Only the leader can update the squad (e.g., changing name/avatar)
      // Or anyone can update the score or territoryCount (prototype simplification)
      allow update: if isAuthenticated() && 
                    isValidSquad(request.resource.data) &&
                    (request.auth.uid == resource.data.leaderId || 
                     request.resource.data.diff(resource.data).affectedKeys().hasAny(['score', 'territoryCount', 'isWeeklyWinner']));
    }

    match /treasures/{treasureId} {
      allow read: if isAuthenticated();
      
      // Treasures are created by the system/admin, but for prototype we might allow clients to spawn them
      allow create: if isAuthenticated() && 
                    hasRequiredFields(['id', 'lat', 'lng', 'coins', 'active', 'createdAt']) &&
                    isValidTreasure(request.resource.data);
                    
      // Anyone can collect a treasure (set active to false)
      allow update: if isAuthenticated() && 
                    isValidTreasure(request.resource.data) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['active']) &&
                    request.resource.data.active == false && resource.data.active == true;
    }

    match /territories/{territoryId} {
      allow read: if isAuthenticated();
      
      // Anyone can claim a territory
      allow create: if isAuthenticated() && 
                    hasRequiredFields(['id', 'ownerId', 'ownerSquadId', 'lat', 'lng', 'createdAt']) &&
                    isValidTerritory(request.resource.data);
                    
      // Anyone can update territory owner
      allow update: if isAuthenticated() && 
                    isValidTerritory(request.resource.data) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerId', 'ownerSquadId']);
    }

    match /attacks/{attackId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    hasRequiredFields(['id', 'attackerId', 'targetId', 'fromLat', 'fromLng', 'toLat', 'toLng', 'timestamp', 'type']) &&
                    isValidAttack(request.resource.data) &&
                    (request.resource.data.attackerId == request.auth.uid || request.resource.data.attackerId.matches('^bot_.*'));
    }

    match /system/{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
